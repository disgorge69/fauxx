<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-build manifest overlay. Currently empty after ACCESS_MOCK_LOCATION moved
    to src/full/AndroidManifest.xml (issue #4 — full release builds also need it so
    Fauxx appears in Developer Options → Select mock location app).

    Hosts HiltTestActivity, the empty @AndroidEntryPoint activity the Compose instrumented
    screen tests launch. compose-bom 2026.05.01 made createAndroidComposeRule reject an activity
    that sets its own content, which MainActivity does.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <activity
            android:name=".ui.HiltTestActivity"
            android:exported="false"
            android:theme="@style/Theme.Fauxx" />
    </application>
</manifest>
