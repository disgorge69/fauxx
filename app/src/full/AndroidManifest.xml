<?xml version="1.0" encoding="utf-8"?>
<!--
    Full (F-Droid / GitHub) flavor manifest overlay.

    Uses "specialUse" foreground-service type — same as the play flavor — because
    Fauxx's runtime behavior (generating synthetic privacy-noise traffic) doesn't
    map to any of the categorical FGS types Android defines. dataSync, in particular,
    is documented as "user-initiated transfer of the user's own data to/from the
    cloud" and is subject to Android 14+'s 6h-per-24h cumulative cap, which made the
    engine appear stopped once the daily window exhausted (issues #64, #65).
    specialUse has no time cap, so switching to it removed that failure mode. F-Droid does
    not enforce Google Play's FGS-type review policy, so we pick by runtime fit
    rather than store rules. The PROPERTY_SPECIAL_USE_FGS_SUBTYPE matches the play
    flavor for consistency, even though F-Droid doesn't require it.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!--
        Mock-location permission for the Location Spoof module. Android's "Select
        mock location app" Developer Options selector lists apps that declare this
        permission. Without it, Fauxx never appears (issue #4). Lint flags this
        with MockLocation because it expects mock-location to be debug-only; we
        ship it in the full/F-Droid flavor deliberately and suppress the warning.

        The play flavor does NOT declare this — Play Store policy is stricter
        around mock location, and the play flavor's specialUse FGS subtype already
        carries reviewer scrutiny that mock location would compound.
    -->
    <uses-permission android:name="android.permission.ACCESS_MOCK_LOCATION"
        tools:ignore="MockLocation" />

    <!--
        Exact-alarm permission for scheduled (quiet-hours) auto-resume (#126). An exact-alarm
        broadcast is an allowed FGS-start context on Android 14+, so AlarmResumeReceiver can
        restart the specialUse foreground service at the scheduled time WITHOUT the user tapping a
        notification (which WorkManager's user-absent context cannot do). USE_EXACT_ALARM is
        auto-granted and non-revocable.

        Full/F-Droid flavor ONLY: Google Play restricts USE_EXACT_ALARM to alarm/calendar-class
        apps, so the play flavor omits it and falls back to the tap-to-resume notification
        (ResumeScheduler checks canScheduleExactAlarms()).
    -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application>
        <service
            android:name=".service.PhantomForegroundService"
            android:foregroundServiceType="specialUse"
            tools:node="merge">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Generates synthetic, off-profile browsing activity continuously in the background to dilute user-identifying signal available to third-party data brokers and ad-tech trackers. The service cannot be an instant-off/on worker because its privacy value depends on maintaining a stable, human-like traffic rhythm (Poisson-distributed cadence, 5-20 minute gaps, circadian quiet hours) that short-lived tasks cannot sustain." />
        </service>
    </application>

</manifest>
